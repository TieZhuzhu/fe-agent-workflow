## 5. 页面接口 — services.ts（Vue 3）

**要点**：接口放页面目录，`export const` + 箭头函数，函数名大驼峰，JSDoc 注释。Vue 2 / Vue 3 写法相同，差异仅在 `.js` / `.ts` 与类型注解。

```ts
import request from '@/config/request'

/** 批量下架列表 */
export const GetBatchList = (data: Record<string, unknown>) =>
  request({ url: 'Product/batchList', data, method: 'post' })

/** 移动商品 */
export const SaveMoveProduct = (data: Record<string, unknown>) =>
  request({ url: 'Product/move', data, method: 'post' })
```

