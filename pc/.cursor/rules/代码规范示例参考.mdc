## 2. Vue 3 弹窗 — MoveProduct/index.vue

```vue
<template>
  <el-dialog v-model="visible" title="移动商品" width="750px">
    <el-form ref="formRef" size="small" :model="form" label-width="100px">
      <el-form-item label="目标分类：" prop="categoryId">
        <CategoryPicker v-model="form.categoryId" placeholder="请选择" />
      </el-form-item>
    </el-form>
    <template #footer>
      <el-button size="small" @click="visible = false">取消</el-button>
      <el-button size="small" type="primary" @click="handleSave">确定</el-button>
    </template>
  </el-dialog>
</template>

<script setup lang="ts">
import { ref, watch } from 'vue'
import type { FormInstance } from 'element-plus'
import { SaveMoveProduct } from '../../services'

const props = defineProps<{ modelValue: boolean }>()
const emit = defineEmits<{ 'update:modelValue': [boolean]; success: [] }>()

const visible = ref(props.modelValue)
const formRef = ref<FormInstance>()
const form = ref({ categoryId: '' })

watch(
  () => props.modelValue,
  (v) => {
    visible.value = v
  }
)
watch(visible, (v) => {
  emit('update:modelValue', v)
})

const handleSave = async () => {
  const valid = await formRef.value?.validate().catch(() => false)
  if (!valid) return
  await SaveMoveProduct(form.value)
  emit('success')
  visible.value = false
}
</script>
```

