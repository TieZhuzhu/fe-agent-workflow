## 3. 子组件 — MoveProduct/index.vue

**要点**：大驼峰目录、`index.vue` 入口、组件独有常量放同目录。

```
components/MoveProduct/
├── index.vue
└── constants.ts    # 仅 MoveProduct 使用的常量
```

```vue
<template>
  <el-dialog title="移动商品" width="750px" :visible.sync="display">
    <el-form size="small" :model="form" label-width="100px" ref="dialogForm">
      <form-item label="目标分类：" prop="categoryId">
        <category v-model="form.categoryId" placeholder="请选择" />
        <div class="form-tip">移动后商品将归属新分类</div>
      </form-item>
    </el-form>
    <div slot="footer" class="dialog-footer">
      <el-button size="small" @click="display = false">取 消</el-button>
      <el-button size="small" type="primary" @click="handleSave">确 定</el-button>
    </div>
  </el-dialog>
</template>

<script>
import { SaveMoveProduct } from '../../services'
import { MOVE_TYPE } from './constants'

export default {
  props: {
    visible: { type: Boolean, default: false }
  },
  data() {
    return { form: { categoryId: '' } }
  },
  computed: {
    display: {
      get() {
        return this.visible
      },
      set(val) {
        this.$emit('update:visible', val)
      }
    }
  },
  methods: {
    handleSave() {
      this.$refs.dialogForm.validate((valid) => {
        if (!valid) return
        SaveMoveProduct({ ...this.form, type: MOVE_TYPE.MOVE }).then(() => {
          this.$emit('success')
          this.display = false
        })
      })
    }
  }
}
</script>
```

