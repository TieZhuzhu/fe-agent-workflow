## index.vue 模板（复杂页入口）

```vue
<template>
  <div class="page-container workbench-page">
    <PageHead :title="PAGE_TITLE" />
    <SummaryCards v-loading="summaryLoading" :data="summary" />
    <el-row :gutter="16">
      <el-col :span="16">
        <TaskPanel
          v-loading="taskLoading"
          :list="tasks"
          @refresh="reloadTasks"
          @action="handleTaskAction"
        />
      </el-col>
      <el-col :span="8">
        <QuickActions @submit="handleQuickSubmit" />
      </el-col>
    </el-row>
  </div>
</template>

<script setup lang="ts">
import { PAGE_TITLE } from './constants'
import { useSummaryCards } from './hooks/useSummaryCards'
import { useTaskList } from './hooks/useTaskList'
import { SummaryCards, TaskPanel, QuickActions } from './components'

const { summary, loading: summaryLoading } = useSummaryCards()
const { tasks, loading: taskLoading, reload: reloadTasks } = useTaskList()

const handleTaskAction = (payload: TaskActionPayload) => {
  // 跨区块编排：如完成任务后刷新统计
  reloadTasks()
}

const handleQuickSubmit = () => {
  reloadTasks()
}
</script>
```

