## 2. Vue 3 列表页 — subPackages/product/list/index.vue

```vue
<template>
  <view class="page">
    <view class="search-bar">
      <input
        v-model="query.keyword"
        class="search-input"
        placeholder="搜索商品"
        confirm-type="search"
        @confirm="handleSearch"
      />
    </view>

    <scroll-view
      scroll-y
      class="list-scroll"
      @scrolltolower="handleLoadMore"
    >
      <view
        v-for="item in list"
        :key="item.id"
        class="product-item"
        @click="handleGoDetail(item)"
      >
        <image class="cover" :src="item.coverUrl" mode="aspectFill" />
        <view class="info">
          <text class="name">{{ item.name ?? '-' }}</text>
          <text class="price">¥{{ item.price ?? '-' }}</text>
        </view>
      </view>

      <view v-if="loading" class="loading-tip">加载中...</view>
      <view v-if="!loading && !list.length" class="empty-tip">暂无商品</view>
      <view v-if="finished && list.length" class="finished-tip">没有更多了</view>
    </scroll-view>
  </view>
</template>

<script setup lang="ts">
import { ref } from 'vue'
import { onLoad, onPullDownRefresh } from '@dcloudio/uni-app'
import { GetProductList } from './services'
import type { ProductItem, ProductListQuery } from './types'

const list = ref<ProductItem[]>([])
const loading = ref(false)
const finished = ref(false)
const query = ref<ProductListQuery>({
  keyword: '',
  pageNo: 1,
  pageSize: 20
})

const loadList = async (reset = false) => {
  if (loading.value) return
  if (reset) {
    query.value.pageNo = 1
    finished.value = false
  }
  if (finished.value) return

  loading.value = true
  try {
    const res = await GetProductList(query.value)
    const rows = res.data ?? []
    list.value = reset ? rows : [...list.value, ...rows]
    if (rows.length < query.value.pageSize) {
      finished.value = true
    } else {
      query.value.pageNo += 1
    }
  } finally {
    loading.value = false
  }
}

const handleSearch = () => loadList(true)

const handleLoadMore = () => loadList()

const handleGoDetail = (item: ProductItem) => {
  uni.navigateTo({
    url: '/subPackages/product/detail?id=' + encodeURIComponent(String(item.id))
  })
}

onLoad(() => {
  loadList(true)
})

onPullDownRefresh(() => {
  loadList(true).finally(() => uni.stopPullDownRefresh())
})
</script>

<style lang="scss" scoped>
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.list-scroll {
  height: calc(100vh - 100rpx);
}

.product-item {
  display: flex;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.info {
  flex: 1;
  margin-left: 20rpx;
}

.name {
  font-size: 28rpx;
  color: #333;
}

.price {
  margin-top: 12rpx;
  font-size: 32rpx;
  color: #e64340;
}
</style>
```

