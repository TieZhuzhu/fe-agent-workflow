## 5. 页面接口 — services.ts（页面级，默认）

```ts
import request from '@/common/request'
import type { ProductListQuery, ProductDetailParams } from './types'

/** 商品列表 */
export const GetProductList = (data: ProductListQuery) =>
  request({ url: '/product/list', data, method: 'post' })

/** 商品详情 */
export const GetProductDetail = (data: ProductDetailParams) =>
  request({ url: '/product/detail', data, method: 'get' })
```

