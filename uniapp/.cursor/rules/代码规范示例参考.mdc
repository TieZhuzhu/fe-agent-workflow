## 10. Vue 2 列表页 — subPackages/order/list/index.vue

```vue
<template>
  <view class="page">
    <view v-for="item in list" :key="item.id" class="order-item" @click="handleGoDetail(item)">
      <text class="order-no">{{ item.orderNo ?? '-' }}</text>
      <text class="status">{{ item.statusDesc ?? '-' }}</text>
    </view>
    <view v-if="!list.length && !loading" class="empty">暂无订单</view>
  </view>
</template>

<script>
import { GetOrderList } from './services'

export default {
  data() {
    return {
      list: [],
      loading: false,
      query: { pageNo: 1, pageSize: 20 }
    }
  },
  onLoad() {
    this.loadList()
  },
  onPullDownRefresh() {
    this.loadList().finally(() => uni.stopPullDownRefresh())
  },
  onReachBottom() {
    this.loadMore()
  },
  methods: {
    async loadList() {
      this.loading = true
      try {
        const res = await GetOrderList(this.query)
        this.list = res.data ?? []
      } finally {
        this.loading = false
      }
    },
    async loadMore() {
      this.query.pageNo += 1
      const res = await GetOrderList(this.query)
      this.list = [...this.list, ...(res.data ?? [])]
    },
    handleGoDetail(item) {
      uni.navigateTo({
        url: '/subPackages/order/detail?id=' + item.id
      })
    }
  }
}
</script>
```

