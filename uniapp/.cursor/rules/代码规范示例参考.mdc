## 4. Vue 3 弹层组件 — components/SkuPicker/index.vue

原生遮罩 + uview 补充示例（复杂选择器可用 `u-popup`）：

```vue
<template>
  <u-popup :show="visible" mode="bottom" round="16" @close="handleClose">
    <view class="sku-panel">
      <text class="title">选择规格</text>
      <view
        v-for="sku in skuList"
        :key="sku.id"
        class="sku-item"
        :class="{ active: sku.id === selectedId }"
        @click="handleSelect(sku)"
      >
        <text>{{ sku.name }}</text>
      </view>
      <button type="primary" @click="handleConfirm">确定</button>
    </view>
  </u-popup>
</template>

<script setup lang="ts">
import { ref, watch } from 'vue'
import type { SkuItem } from './types'

const props = defineProps<{
  modelValue: boolean
  skuList: SkuItem[]
}>()

const emit = defineEmits<{
  'update:modelValue': [boolean]
  confirm: [SkuItem]
}>()

const visible = ref(props.modelValue)
const selectedId = ref('')

watch(() => props.modelValue, (v) => { visible.value = v })
watch(visible, (v) => emit('update:modelValue', v))

const handleSelect = (sku: SkuItem) => {
  selectedId.value = sku.id
}

const handleConfirm = () => {
  const sku = props.skuList.find((s) => s.id === selectedId.value)
  if (!sku) {
    uni.showToast({ title: '请选择规格', icon: 'none' })
    return
  }
  emit('confirm', sku)
  visible.value = false
}

const handleClose = () => {
  visible.value = false
}
</script>
```

